generator client {
  provider     = "prisma-client"
  output       = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  gender       Gender
  passwordHash String
  status       UserStatus @default(PENDING_VERIFICATION)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum Gender {
  MALE
  FEMALE
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  INACTIVE
  BANNED
}

model DoctorProfile {
  id              String @id @default(uuid())
  name            String
  specialization  String
  university      String
  yearsExperience Int

  patientsNumber   Int
  clinicsPlaces    String
  consultationFees Float

  bookDate  DateTime?
  time      String?
  partOfDay String?

  profilePic String?

  about  String?
  rating Float   @default(0)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  clinics   Clinic[]
  schedules Schedule[]
}

model Clinic {
  id       String @id @default(uuid())
  doctorId String

  name    String
  address String
  fees    Float

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}

enum DayPeriod {
  MORNING
  AFTERNOON
  EVENING
}

model Schedule {
  id       String @id @default(uuid())
  doctorId String

  date      DateTime
  startTime String
  period    DayPeriod

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}
