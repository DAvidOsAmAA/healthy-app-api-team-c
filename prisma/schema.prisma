generator client {
  provider        = "prisma-client"
  output          = "../src/generated"
  moduleFormat    = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  gender       Gender
  passwordHash String
  status       UserStatus @default(PENDING_VERIFICATION)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  recentSearches   RecentSearch[]
}

model Doctor {
  id          String      @id @default(uuid())
  name        String
  specialtyId String
  gender      Gender
  title       DoctorTitle
  location    String
  price       Float
  rating      Float       @default(0)
  viewsCount  Int         @default(0)
  createdAt   DateTime    @default(now())

  @@index([specialtyId, rating])
  @@index([location, price])
  @@index([name])
}

model RecentSearch {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  term      String   // الاسم اللي ظهر وضغط عليه (اسم دكتور أو اسم تخصص)
  type      String   // نوع النتيجة: 'doctor' أو 'specialty'
  targetId  String   // الـ ID بتاع الدكتور أو التخصص
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)]) // Index مركب لضمان جلب أخر 5 بسرعة طلقة
}

enum DoctorTitle {
  PROFESSOR
  CONSULTANT
  SPECIALIST
}

enum Gender {
  MALE
  FEMALE
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  INACTIVE
  BANNED
}

model DoctorProfile {
  id              String @id @default(uuid())
  name            String
  specialization  String
  university      String
  yearsExperience Int

  patientsNumber   Int
  clinicsPlaces    String
  consultationFees Float

  bookDate  DateTime?
  time      String?
  partOfDay String?

  profilePic String?

  about  String?
  rating Float   @default(0)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  clinics   Clinic[]
  schedules Schedule[]
}

model Clinic {
  id       String @id @default(uuid())
  doctorId String

  name    String
  address String
  fees    Float

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}

enum DayPeriod {
  MORNING
  AFTERNOON
  EVENING
}

model Schedule {
  id       String @id @default(uuid())
  doctorId String

  date      DateTime
  startTime String
  period    DayPeriod

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())

}
model WelcomeConfig {
  id                 Int      @id @default(autoincrement())
  logoUrl            String
  supportPhone       String
  googleAuthEnabled  Boolean  @default(true)
  
  banners            Banner[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Banner {
  id              Int           @id @default(autoincrement())
  imageUrl        String
  title           String
  description     String
  
  configId        Int
  welcomeConfig   WelcomeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
