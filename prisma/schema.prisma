generator client {
   provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  gender       Gender
  passwordHash String
  status       UserStatus @default(PENDING_VERIFICATION)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Doctor {
  id          String      @id @default(uuid())
  name        String
  specialtyId String
  gender      Gender
  title       DoctorTitle
  location    String
  price       Float
  rating      Float       @default(0)
  viewsCount  Int         @default(0)
  createdAt   DateTime    @default(now())

  @@index([specialtyId, rating])
  @@index([location, price])
}

enum DoctorTitle {
  PROFESSOR
  CONSULTANT
  SPECIALIST
}

enum Gender {
  MALE
  FEMALE
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  INACTIVE
  BANNED
}

model DoctorProfile {
  id              String @id @default(uuid())
  name            String
  specialization  String
  university      String
  yearsExperience Int

  patientsNumber   Int
  clinicsPlaces    String
  consultationFees Float

  bookDate  DateTime?
  time      String?
  partOfDay String?

  profilePic String?

  about  String?
  rating Float   @default(0)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  clinics   Clinic[]
  schedules Schedule[]
}

model Clinic {
  id       String @id @default(uuid())
  doctorId String

  name    String
  address String
  fees    Float

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
}

enum DayPeriod {
  MORNING
  AFTERNOON
  EVENING
}

model Schedule {
  id       String @id @default(uuid())
  doctorId String

  date      DateTime
  startTime String
  period    DayPeriod

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())

}

model WelcomeConfig {
  id                 Int      @id @default(autoincrement())
  logoUrl            String
  supportPhone       String
  googleAuthEnabled  Boolean  @default(true)
  
  banners            Banner[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Banner {
  id              Int           @id @default(autoincrement())
  imageUrl        String
  title           String
  description     String
  
  configId        Int
  welcomeConfig   WelcomeConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
